# BMP — Environment Variables
#
# Copy this file to ~/.bmp.env on your machine and fill in your keys.
# NEVER commit actual keys to git.

# Required: Anthropic API key for prompt generation
ANTHROPIC_API_KEY=sk-ant-...

# Internal: GitHub token for auto-updater (bundled by the build system — do not set manually)
# GH_TOKEN is injected at build time via .env — use a fine-grained PAT with contents:read only
