{
  "name": "bmp",
  "version": "1.3.5",
  "description": "Brotherhood Marketing Prompts — Electron desktop app",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:mac": "electron-vite build && electron-builder --mac",
    "release": "electron-vite build && electron-builder --publish always",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Brotherhood",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@higgsfield/client": "^0.2.1",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.brotherhood.bmp",
    "productName": "BMP",
    "publish": {
      "provider": "github",
      "owner": "createdbynoone",
      "repo": "bmp",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "background": "build/background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 130, "y": 216, "type": "file" },
        { "x": 410, "y": 216, "type": "link", "path": "/Applications" }
      ],
      "iconSize": 80
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*.png"
        ]
      }
    ]
  }
}
